{
  "name": "unduhin-extension",
  "version": "1.1.1",
  "description": "Chromium extension that hands downloads to the Unduhin native app over Native Messaging.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.278",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "bun@1.3.5"
}
