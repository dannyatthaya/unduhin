{
  "manifest_version": 3,
  "name": "Unduhin",
  "version": "1.1.7",
  "description": "Hand browser downloads to the Unduhin native app. Captures cookies, referer, and headers so authenticated downloads keep working.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "downloads",
    "webRequest",
    "nativeMessaging",
    "cookies",
    "contextMenus",
    "storage",
    "tabs",
    "notifications",
    "webNavigation",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Unduhin",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
