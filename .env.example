# Local secrets for scripts/release.ps1. Copy this file to `.env` (which is
# gitignored) and fill in the values — release.ps1 loads `.env` automatically,
# so these no longer need to be exported by hand in every shell.
#
# Tauri updater signing key + its password, used by `cargo tauri build` to sign
# the NSIS installer (createUpdaterArtifacts). Generate a keypair with:
#   bun tauri signer generate -w unduhin-updater.key
# TAURI_SIGNING_PRIVATE_KEY may be either the key file's CONTENT (base64) or a
# filesystem path to the key file. The password is whatever you set at generate
# time (empty string if you generated without one).
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
